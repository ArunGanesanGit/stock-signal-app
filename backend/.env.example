NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:3000

# API Keys (Get free keys from the services below)
# AlphaVantage: https://www.alphavantage.co/ (for stock prices & technical indicators)
ALPHA_VANTAGE_API_KEY=

# NewsAPI: https://newsapi.org/ (for news & sentiment analysis)
NEWSAPI_KEY=

# If both API keys are empty, the app will use mock data automatically
USE_MOCK_DATA=false

# AWS Lambda (if deploying to AWS)
AWS_REGION=us-east-1
AWS_LAMBDA_FUNCTION_NAME=stock-signal-api
